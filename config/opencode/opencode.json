{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.opencode/auth.json": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "todowrite": "allow"
  }
}

